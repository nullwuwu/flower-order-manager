{
  "name": "flower-order-manager",
  "version": "1.0.0",
  "description": "Flower order management desktop app",
  "main": "dist-electron/main/main.js",
  "author": "codex",
  "license": "MIT",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js -k \"npm:dev:renderer\" \"npm:dev:electron:tsc\" \"npm:dev:electron:run\"",
    "dev:stop": "pkill -f \"/Users/a1/Desktop/workspace/花店订单管理系统/node_modules/concurrently/dist/bin/concurrently.js\" || true",
    "dev:renderer": "node ./node_modules/vite/bin/vite.js",
    "dev:electron:tsc": "node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch",
    "dev:electron:run": "node ./node_modules/wait-on/bin/wait-on tcp:5173 dist-electron/main/main.js && node ./node_modules/electron/cli.js .",
    "build:renderer": "node ./node_modules/vite/bin/vite.js build",
    "build:electron": "node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "node ./node_modules/electron/cli.js .",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "pack:win": "npm run build && node ./node_modules/electron-builder/cli.js --win nsis --x64 --ia32",
    "pack:mac": "npm run build && node ./node_modules/electron-builder/cli.js --mac dmg"
  },
  "build": {
    "appId": "com.flower.order.manager",
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-resources/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "publisherName": "Flower Order Manager"
    },
    "mac": {
      "icon": "build-resources/icon.icns",
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.3.2",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
